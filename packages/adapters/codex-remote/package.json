{
  "name": "@right-link/paperclip-plugin-codex-remote",
  "version": "0.3.1",
  "description": "Standalone external Codex sandbox adapter for Paperclip (fork add-on, installed via the adapter plugin store)",
  "license": "MIT",
  "homepage": "https://github.com/paperclipai/paperclip",
  "bugs": {
    "url": "https://github.com/paperclipai/paperclip/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/paperclipai/paperclip",
    "directory": "packages/adapters/codex-remote"
  },
  "type": "module",
  "paperclip": {
    "adapterType": "codex_remote",
    "adapterUiParser": "1.0.0"
  },
  "exports": {
    ".": "./src/server/adapter.ts",
    "./server": "./src/server/index.ts",
    "./meta": "./src/index.ts",
    "./ui": "./src/ui/index.ts",
    "./ui-parser": "./dist/ui-parser.js",
    "./cli": "./src/cli/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/server/adapter.d.ts",
        "import": "./dist/server/adapter.js"
      },
      "./server": {
        "types": "./dist/server/index.d.ts",
        "import": "./dist/server/index.js"
      },
      "./meta": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./ui": {
        "types": "./dist/ui/index.d.ts",
        "import": "./dist/ui/index.js"
      },
      "./ui-parser": {
        "import": "./dist/ui-parser.js"
      },
      "./cli": {
        "types": "./dist/cli/index.d.ts",
        "import": "./dist/cli/index.js"
      }
    },
    "main": "./dist/server/adapter.js",
    "types": "./dist/server/adapter.d.ts"
  },
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
    "build": "tsc && pnpm run build:ui-parser",
    "build:ui-parser": "pnpm exec esbuild src/ui-parser.ts --bundle --format=cjs --platform=browser --outfile=dist/ui-parser.js",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "probe:quota": "pnpm exec tsx src/cli/quota-probe.ts --json"
  },
  "dependencies": {
    "@paperclipai/adapter-utils": "workspace:*",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.7.3"
  }
}
